<!DOCTYPE html>
<html lang="en">
{{> head}}
<body>
{{> header}}
<main class="wrap">
<article>
  <h1>Book: {{course.title}}</h1>
  <p class="muted">
    Level: {{course.level}} • Type: {{course.type}} {{#course.allowDropIn}}• Drop-in available{{/course.allowDropIn}}
  </p>
  <p>{{course.description}}</p>
  <p class="muted">Price: &pound; {{course.price}} {{#course.allowDropIn}}per session{{/course.allowDropIn}}{{^course.allowDropIn}}per course{{/course.allowDropIn}}</p>
  <p class="muted">Location: {{course.location}}</p>
  <p class="muted">Dates: {{course.startDate}} – {{course.endDate}}</p>

  {{#errors}}
  <div class="alert error" role="alert" aria-live="assertive">
    <ul>
      {{#list}}
      <li>{{.}}</li>
      {{/list}}
    </ul>
  </div>
  {{/errors}}

  <form method="post" action="/courses/{{course.id}}/book">
    <input type="hidden" name="userId" value="{{user._id}}">

    <fieldset>
      <legend>Your details</legend>

      <div class="field">
        <label for="name">Full name</label>
        <input id="name" name="name" type="text" required value="{{user.name}}">
      </div>

      <div class="field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required value="{{user.email}}">
      </div>

      <div class="field">
        <label for="notes">Notes (injuries, preferences)</label>
        <textarea id="notes" name="notes" rows="4" placeholder="Optional">{{notes}}</textarea>
      </div>

      <div class="field checkbox">
        <input id="consent" name="consent" type="checkbox" required>
        <label for="consent">I agree to the studio booking terms and health disclaimer.</label>
      </div>
    </fieldset>

    <fieldset>
      <legend>Booking summary</legend>
      <p>This booking reserves a seat across <strong>{{sessionsCount}}</strong> sessions:</p>
      <ul class="muted">
        {{#sessions}}
        <li>{{start}} • {{location}} ({{remaining}} places left)</li>
        {{/sessions}}
      </ul>
    </fieldset>

    <div class="actions">
      <button class="btn primary" type="submit">Confirm Course Booking</button>
      <a class="btn secondary" href="/courses/{{course.id}}">Cancel</a>
    </div>
  </form>
</article>
</main>
{{> footer}}
</body>
</html>