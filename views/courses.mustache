<!DOCTYPE html>
<html lang="en">
{{> head}}
<body>
{{> header}}
<main class="wrap">
<section class="filters">
  <form class="filter-form" method="get" action="/courses">
    <label class="field">
      Level
      <select name="level">
        <option value="" {{^filters.level}}selected{{/filters.level}}>Any</option>
        <option value="beginner" {{#filters.isBeginner}}selected{{/filters.isBeginner}}>Beginner</option>
        <option value="intermediate" {{#filters.isIntermediate}}selected{{/filters.isIntermediate}}>Intermediate</option>
        <option value="advanced" {{#filters.isAdvanced}}selected{{/filters.isAdvanced}}>Advanced</option>
      </select>
    </label>

    <label class="field">
      Search
      <input type="search" name="q" value="{{filters.q}}" placeholder="Title or description" />
    </label>

    <div>
      <button class="btn primary" type="submit">Apply</button>
      <a class="btn secondary" href="/courses">Reset</a>
    </div>
  </form>
</section>

<div class="cards">
  {{#courses}}
  <article class="card">
    <h2>{{title}}</h2>
    <p class="muted">
      Level: {{level}} • Type: {{type}} {{#allowDropIn}}• Drop-in OK{{/allowDropIn}}
    </p>
    <p>{{description}}</p>
    <p class="muted">Price: &pound; {{price}} {{#allowDropIn}}per session{{/allowDropIn}}{{^allowDropIn}}per course{{/allowDropIn}}</p>
    <p class="muted">Location: {{location}}</p>
    <p class="muted">Dates: {{startDate}} – {{endDate}}</p>
    <p class="muted">Next session: {{nextSession}} • Sessions: {{sessionsCount}}</p>
    <div>
      <a class="btn secondary" href="/courses/{{id}}/bookings">View bookings</a>
      <a class="btn secondary" href="/courses/{{id}}/edit">Update</a>
      <form class="inline-form" method="post" action="/courses/{{id}}/delete">
        <button class="btn link-style" type="submit" onclick="return confirm('Are you sure you want to delete this course?');">Delete</button>
      </form>
    </div>
  </article>
  {{/courses}}

  {{^courses}}
    <p>No courses match your filters.</p>
  {{/courses}}
</div>
<!-- 
<nav class="pagination">
  {{#pagination.hasPrev}}
    {{pagination.prevLink}}← Previous</a>
  {{/pagination.hasPrev}}

  <span class="muted">Page {{pagination.page}} of {{pagination.totalPages}}</span>

  {{#pagination.hasNext}}
    {{pagination.nextLink}}Next →</a>
  {{/pagination.hasNext}}
</nav> -->
</main>
{{> footer}}
</body>
</html>