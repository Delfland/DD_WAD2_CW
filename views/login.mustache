<!DOCTYPE html>
<html lang="en">
{{> head}}
<body>
{{> header}}
<main class="wrap">
<article>
  <h1>Sign In</h1>
  <p class="muted">Access your account to book courses and sessions.</p>

  {{#hasError}}
  <div class="alert error" role="alert" aria-live="assertive">
    {{error}}
  </div>
  {{/hasError}}

  <form method="post" action="/login" autocomplete="off">
    <div class="field">
      <label for="email">Email</label>
      <input id="email" name="email" type="email" required value="{{values.email}}" autocomplete="username" autocapitalize="none" />
    </div>

    <div class="field">
      <label for="password">Password</label>
      <input id="password" name="password" type="password" required autocomplete="current-password" />
    </div>

    <div class="actions">
      <button class="btn primary" type="submit">Sign In</button>
      <a class="btn secondary" href="/register">Create account</a>
    </div>
  </form>
</article>
</main>
{{> footer}}
</body>
</html>