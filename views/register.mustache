<!DOCTYPE html>
<html lang="en">
{{> head}}
<body>
{{> header}}
<main class="wrap">
<article>
  <h1>Create Account</h1>
  <p class="muted">Register to manage your course and session bookings.</p>

  {{#hasError}}
  <div class="alert error" role="alert" aria-live="assertive">
    {{error}}
  </div>
  {{/hasError}}

  <form method="post" action="/register" autocomplete="off">
    <div class="field">
      <label for="name">Full name</label>
      <input id="name" name="name" type="text" required value="{{values.name}}" autocomplete="name" />
    </div>

    <div class="field">
      <label for="email">Email</label>
      <input id="email" name="email" type="email" required value="{{values.email}}" autocomplete="email" autocapitalize="none" />
    </div>

    <div class="field">
      <label for="password">Password</label>
      <input id="password" name="password" type="password" required minlength="8" autocomplete="new-password" />
    </div>

    <div class="actions">
      <button class="btn primary" type="submit">Create account</button>
      <a class="btn secondary" href="/login">Already have an account?</a>
    </div>
  </form>
</article>
</main>
{{> footer}}
</body>
</html>