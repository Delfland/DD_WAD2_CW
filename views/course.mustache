<!DOCTYPE html>
<html lang="en">
{{> head}}
<body>
{{> header}}
<main class="wrap">
<article>
  <h1>{{course.title}}</h1>
  <p class="muted">
    Level: {{course.level}} • Type: {{course.type}} {{#course.allowDropIn}}• Drop-in available{{/course.allowDropIn}}
  </p>
  <p>{{course.description}}</p>
  <p class="muted">Price: &pound; {{course.price}} {{#course.allowDropIn}}per session{{/course.allowDropIn}}{{^course.allowDropIn}}per course{{/course.allowDropIn}}</p>
  <p class="muted">Dates: {{course.startDate}} – {{course.endDate}}</p>

  <section>
    <h2>Book the full course</h2>
   <form action="/courses/{{course.id}}/book" method="post">  <!-- If you add CSRF later: <input type="hidden" name="_csrf" value="{{csrfToken}}"> -->
      <input type="hidden" name="userId" value="{{user._id}}">
      <button class="btn primary" type="submit">
        {{#course.isFull}}Add to waitlist{{/course.isFull}}
        {{^course.isFull}}Book full course{{/course.isFull}}
      </button>
    </form>
  </section>

  <section>
    <h2>Sessions</h2>
    <table class="table">
      <thead>
        <tr>
          <th>Start</th>
          <th>End</th>
          <th>Location</th>
          <th>Capacity</th>
          <th>Booked</th>
          <th>Remaining</th>
          {{#course.allowDropIn}}<th></th>{{/course.allowDropIn}}
        </tr>
      </thead>
      <tbody>
        {{#sessions}}
        <tr>
          <td>{{start}}</td>
          <td>{{end}}</td>
          <td>{{location}}</td>
          <td>{{capacity}}</td>
          <td>{{booked}}</td>
          <td>{{remaining}}</td>
          {{#allowDropIn}}<td>
            <form action="/sessions/{{id}}/book" method="post">
              <button class="btn secondary" type="submit">
                {{#isFull}}Add to waitlist{{/isFull}}
                {{^isFull}}Book this session{{/isFull}}
              </button>
            </form>
          </td>{{/allowDropIn}}
        </tr>
        {{/sessions}}
      </tbody>
    </table>
  </section>
</article>
</main>
{{> footer}}
</body>
</html>